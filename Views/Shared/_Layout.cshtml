<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicAdminApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClinicAdminApp.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            body {
                overflow-x: hidden;
                background: #f5f6fa;
            }

            .sidebar {
                width: 260px;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background: #0d6efd;
                color: white;
                overflow-y: auto;
            }

            .sidebar .nav-link {
                color: white;
                padding: 12px 20px;
                border-radius: 8px;
                margin: 4px 10px;
            }

            .sidebar .nav-link:hover {
                background: rgba(255, 255, 255, .15);
            }

            .sidebar .nav-link.active {
                background: white;
                color: #0d6efd;
                font-weight: bold;
            }

            .content {
                margin-left: 260px;
                padding: 20px;
            }

            .brand {
                font-size: 24px;
                font-weight: bold;
                padding: 20px;
                text-align: center;
                border-bottom: 1px solid rgba(255, 255, 255, .2);
            }

            .menu-title {
                font-size: 13px;
                color: #d9e5ff;
                padding: 15px 20px 5px;
                text-transform: uppercase;
            }
    </style>

</head>

<body>
    <div class="sidebar">

        <div class="brand">

            <i class="bi bi-hospital-fill"></i>

            Clinic Admin

        </div>

        <div class="menu-title">Dashboard</div>

        <a asp-controller="Dashboard" asp-action="Index" class="nav-link">

            <i class="bi bi-speedometer2"></i>

            Dashboard

        </a>

        <div class="menu-title">Master Data</div>

        <a asp-controller="Dokter" asp-action="Index" class="nav-link">
            <i class="bi bi-person-badge-fill"></i>
            Dokter
        </a>

        <a asp-controller="Pasien" asp-action="Index" class="nav-link">
            <i class="bi bi-people-fill"></i>
            Pasien
        </a>

        <a asp-controller="Poli" asp-action="Index" class="nav-link">
            <i class="bi bi-hospital"></i>
            Poli
        </a>

        <a asp-controller="Obat" asp-action="Index" class="nav-link">
            <i class="bi bi-capsule-pill"></i>
            Obat
        </a>

        <div class="menu-title">Transaksi</div>

        <a asp-controller="Pendaftaran" asp-action="Index" class="nav-link">
            <i class="bi bi-journal-medical"></i>
            Pendaftaran
        </a>

        <a asp-controller="Pemeriksaan" asp-action="Index" class="nav-link">
            <i class="bi bi-heart-pulse-fill"></i>
            Pemeriksaan
        </a>

        <a asp-controller="Resep" asp-action="Index" class="nav-link">
            <i class="bi bi-file-earmark-medical-fill"></i>
            Resep
        </a>

        <a asp-controller="Pembayaran" asp-action="Index" class="nav-link">
            <i class="bi bi-cash-stack"></i>
            Pembayaran
        </a>

    </div>

    <div class="content">

        <nav class="navbar navbar-expand-lg bg-white rounded shadow-sm mb-4">

            <div class="container-fluid">

                <span class="navbar-brand mb-0 h4">

                    @ViewData["Title"]

                </span>

            </div>

        </nav>

        @RenderBody()

    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

    

        </html >