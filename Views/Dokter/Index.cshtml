@model IEnumerable<ClinicAdminApp.Models.Dokter>

@{
    ViewData["Title"] = "Data Dokter";
    int no = 1;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">

        <h2>Data Dokter</h2>

        <div>

            <a asp-action="ExportPdf" class="btn btn-danger">

                Export PDF

            </a>

            <a asp-action="Create" class="btn btn-primary">

                Tambah Dokter

            </a>

        </div>

    </div>
    <div class="row mb-3">

        <div class="col-md-6">

            <form asp-action="Index" method="get">

                <div class="input-group">

                    <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                           placeholder="Cari nama dokter, spesialis, atau No STR..." />

                    <button class="btn btn-primary" type="submit">
                        Cari
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Reset
                    </a>

                </div>

            </form>

        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>

                <th>No</th>
                <th>Nama Dokter</th>
                <th>Spesialis</th>
                <th>No STR</th>
                <th>No Telepon</th>
                <th>Jadwal</th>
                <th width="180">Aksi</th>

            </tr>

        </thead>

        <tbody>

            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>

                        <td>@no</td>
                        <td>@item.NamaDokter</td>
                        <td>@item.Spesialis</td>
                        <td>@item.NoSTR</td>
                        <td>@item.NoTelepon</td>
                        <td>@item.JadwalPraktek</td>

                        <td>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                Hapus
                            </a>

                        </td>

                    </tr>

                    no++;
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">
                        Belum ada data dokter.
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>
