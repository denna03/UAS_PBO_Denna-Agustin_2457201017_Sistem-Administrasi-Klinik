@model ClinicAdminApp.Models.Dokter

@{
    ViewData["Title"] = "Tambah Dokter";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Tambah Data Dokter</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="NamaDokter" class="form-label"></label>
                    <input asp-for="NamaDokter" class="form-control" />
                    <span asp-validation-for="NamaDokter" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Spesialis" class="form-label"></label>
                    <input asp-for="Spesialis" class="form-control" />
                    <span asp-validation-for="Spesialis" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NoSTR" class="form-label"></label>
                    <input asp-for="NoSTR" class="form-control" />
                    <span asp-validation-for="NoSTR" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NoTelepon" class="form-label"></label>
                    <input asp-for="NoTelepon" class="form-control" />
                    <span asp-validation-for="NoTelepon" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="JadwalPraktek" class="form-label"></label>
                    <input asp-for="JadwalPraktek" class="form-control" />
                    <span asp-validation-for="JadwalPraktek" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">
                    Simpan
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Kembali
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
