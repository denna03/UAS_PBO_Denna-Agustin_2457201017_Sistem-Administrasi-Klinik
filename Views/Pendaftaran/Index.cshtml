@model IEnumerable<ClinicAdminApp.Models.Pendaftaran>

@{
    ViewData["Title"] = "Pendaftaran Pasien";
    int no = 1;
}

<div class="container mt-4">

    <partial name="_Alert"/>

    <div class="d-flex justify-content-between mb-3">

        <h2>Pendaftaran Pasien</h2>

        <a asp-action="Create"
           class="btn btn-primary">
            Pendaftaran Baru
        </a>

    </div>

    <table class="table table-bordered table-striped">

        <thead class="table-dark">

            <tr>

                <th>No</th>
                <th>No Registrasi</th>
                <th>Tanggal</th>
                <th>Pasien</th>
                <th>Dokter</th>
                <th>Poli</th>
                <th>Status</th>
                <th width="180">Aksi</th>

            </tr>

        </thead>

        <tbody>

        @if(Model.Any())
        {
            @foreach(var item in Model)
            {
                <tr>

                    <td>@no</td>

                    <td>@item.NoPendaftaran</td>

                    <td>
                        @item.TanggalBerobat.ToString("dd-MM-yyyy")
                    </td>

                    <td>@item.Pasien?.NamaPasien</td>

                    <td>@item.Dokter?.NamaDokter</td>

                    <td>@item.Poli?.NamaPoli</td>

                    <td>

                        @if(item.Status=="Menunggu")
                        {
                            <span class="badge bg-warning text-dark">
                                Menunggu
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                @item.Status
                            </span>
                        }

                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Hapus
                        </a>

                    </td>

                </tr>

                no++;
            }
        }

        </tbody>

    </table>

</div>