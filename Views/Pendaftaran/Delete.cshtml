@model ClinicAdminApp.Models.Pendaftaran

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-danger text-white">

            <h3>Hapus Pendaftaran</h3>

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                Apakah Anda yakin ingin menghapus data pendaftaran ini?

            </div>

            <table class="table table-bordered">

                <tr>
                    <th>No Registrasi</th>
                    <td>@Model.NoPendaftaran</td>
                </tr>

                <tr>
                    <th>Pasien</th>
                    <td>@Model.Pasien?.NamaPasien</td>
                </tr>

                <tr>
                    <th>Dokter</th>
                    <td>@Model.Dokter?.NamaDokter</td>
                </tr>

                <tr>
                    <th>Poli</th>
                    <td>@Model.Poli?.NamaPoli</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>@Model.Status</td>
                </tr>

            </table>

            <form asp-action="Delete" method="post">

                <input type="hidden" asp-for="Id"/>

                <button class="btn btn-danger">
                    Hapus
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Batal
                </a>

            </form>

        </div>

    </div>

</div>