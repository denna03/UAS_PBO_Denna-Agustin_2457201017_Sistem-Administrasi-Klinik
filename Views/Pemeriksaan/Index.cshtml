@model IEnumerable<ClinicAdminApp.Models.Pemeriksaan>

@{
    ViewData["Title"] = "Pemeriksaan";
    int no = 1;
}

<div class="container mt-4">

    <partial name="_Alert"/>

    <div class="d-flex justify-content-between mb-3">

        <h2>Pemeriksaan Pasien</h2>

        <a asp-action="Create"
           class="btn btn-primary">
            Pemeriksaan Baru
        </a>

    </div>

    <table class="table table-bordered table-striped">

        <thead class="table-dark">

            <tr>

                <th>No</th>
                <th>No Registrasi</th>
                <th>Pasien</th>
                <th>Diagnosa</th>
                <th>Tanggal</th>
                <th width="180">Aksi</th>

            </tr>

        </thead>

        <tbody>

        @if(Model.Any())
        {
            @foreach(var item in Model)
            {
                <tr>

                    <td>@no</td>

                    <td>@item.Pendaftaran?.NoPendaftaran</td>

                    <td>@item.Pendaftaran?.Pasien?.NamaPasien</td>

                    <td>@item.Diagnosa</td>

                    <td>
                        @item.TanggalPemeriksaan.ToString("dd-MM-yyyy")
                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Hapus
                        </a>

                    </td>

                </tr>

                no++;
            }
        }

        </tbody>

    </table>

</div>