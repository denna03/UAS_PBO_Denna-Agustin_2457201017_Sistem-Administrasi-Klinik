@model ClinicAdminApp.Models.Pemeriksaan

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-danger text-white">

            <h3>Hapus Pemeriksaan</h3>

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                Apakah Anda yakin ingin menghapus data pemeriksaan ini?

            </div>

            <table class="table table-bordered">

                <tr>
                    <th>No Registrasi</th>
                    <td>@Model.Pendaftaran?.NoPendaftaran</td>
                </tr>

                <tr>
                    <th>Pasien</th>
                    <td>@Model.Pendaftaran?.Pasien?.NamaPasien</td>
                </tr>

                <tr>
                    <th>Diagnosa</th>
                    <td>@Model.Diagnosa</td>
                </tr>

                <tr>
                    <th>Tanggal</th>
                    <td>@Model.TanggalPemeriksaan.ToString("dd-MM-yyyy")</td>
                </tr>

            </table>

            <form asp-action="Delete" method="post">

                <input type="hidden" asp-for="Id"/>

                <button class="btn btn-danger">
                    Hapus
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Batal
                </a>

            </form>

        </div>

    </div>

</div>