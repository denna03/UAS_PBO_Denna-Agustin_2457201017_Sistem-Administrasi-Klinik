@model IEnumerable<ClinicAdminApp.Models.Obat>

@{
    ViewData["Title"] = "Data Obat";
    int no = 1;
}

<div class="container mt-4">

    <partial name="_Alert" />

    <div class="d-flex justify-content-between mb-3">

        <h2>Data Obat</h2>

        <a asp-action="Create" class="btn btn-primary">
            Tambah Obat
        </a>

    </div>

    <form asp-action="Index" method="get" class="mb-3">

        <div class="input-group">

            <input class="form-control" name="search" value="@ViewBag.Search"
                   placeholder="Cari kode atau nama obat..." />

            <button class="btn btn-primary">
                Cari
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Reset
            </a>

        </div>

    </form>

    <table class="table table-bordered table-striped">

        <thead class="table-dark">

            <tr>

                <th>No</th>
                <th>Kode</th>
                <th>Nama</th>
                <th>Kategori</th>
                <th>Harga</th>
                <th>Stok</th>
                <th>Expired</th>
                <th width="170">Aksi</th>

            </tr>

        </thead>

        <tbody>

            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>

                        <td>@no</td>

                        <td>@item.KodeObat</td>

                        <td>@item.NamaObat</td>

                        <td>@item.Kategori</td>

                        <td>
                            Rp @item.Harga.ToString("N0")
                        </td>

                        <td>

                            @if (item.Stok <= 10)
                            {
                                <span class="badge bg-danger">
                                    @item.Stok
                                </span>
                            }
                            else
                            {
                                @item.Stok
                            }

                        </td>

                        <td>
                            @item.TanggalExpired.ToString("dd-MM-yyyy")
                        </td>

                        <td>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                Hapus
                            </a>

                        </td>

                    </tr>

                    no++;
                }
            }
            else
            {
                <tr>

                    <td colspan="8" class="text-center">
                        Belum ada data obat.
                    </td>

                </tr>
            }

        </tbody>

    </table>
    <a asp-action="ExportPdf" class="btn btn-danger">

        Export PDF

    </a>
</div>, 
