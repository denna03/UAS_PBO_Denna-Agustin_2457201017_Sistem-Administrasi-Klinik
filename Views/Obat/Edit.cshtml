@model ClinicAdminApp.Models.Obat

@{
    ViewData["Title"] = "Edit Obat";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning">
            <h3>Edit Data Obat</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id"/>

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="KodeObat"></label>
                    <input asp-for="KodeObat" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="NamaObat"></label>
                    <input asp-for="NamaObat" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="Kategori"></label>
                    <input asp-for="Kategori" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="Satuan"></label>
                    <input asp-for="Satuan" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="Harga"></label>
                    <input asp-for="Harga" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="Stok"></label>
                    <input asp-for="Stok" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="TanggalExpired"></label>
                    <input asp-for="TanggalExpired"
                           type="date"
                           class="form-control"/>
                </div>

                <button class="btn btn-warning">
                    Update
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Kembali
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
}